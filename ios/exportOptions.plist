<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>destination</key>
	<string>export</string>
	<key>manageAppVersionAndBuildNumber</key>
	<true/>
	<key>method</key>
	<string>app-store</string>
	<!-- Replace provisioning profile names after creating them in Apple Developer / Xcode. -->
	<key>provisioningProfiles</key>
	<dict>
		<key>com.mkstudio.vpn</key>
		<string>MK Studio VPN AppStore</string>
		<key>com.mkstudio.vpn.HiddifyPacketTunnel</key>
		<string>MK Studio VPN PacketTunnel AppStore</string>
	</dict>
	<!-- signingCertificate / teamID: set when you have a paid Apple Developer account ($99/yr). -->
	<key>signingStyle</key>
	<string>automatic</string>
	<key>stripSwiftSymbols</key>
	<true/>
	<key>teamID</key>
	<string>YOUR_TEAM_ID</string>
	<key>uploadSymbols</key>
	<true/>
</dict>
</plist>
